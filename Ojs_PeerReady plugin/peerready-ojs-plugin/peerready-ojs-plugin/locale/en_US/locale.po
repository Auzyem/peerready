# ── Plugin identity ───────────────────────────────────────────────────────────

msgid "plugins.generic.peerready.displayName"
msgstr "PeerReady AI Manuscript Review"

msgid "plugins.generic.peerready.description"
msgstr "Automatically submits manuscripts to PeerReady for AI-powered peer review scoring, adversarial critique, and journal-fit recommendations. Review reports are attached to the OJS submission workflow."

# ── Sidebar ───────────────────────────────────────────────────────────────────

msgid "plugins.generic.peerready.sidebarTitle"
msgstr "PeerReady AI Review"

msgid "plugins.generic.peerready.viewReport"
msgstr "View full report"

msgid "plugins.generic.peerready.sessionId"
msgstr "Session"

# ── Status badges ─────────────────────────────────────────────────────────────

msgid "plugins.generic.peerready.status.pending"
msgstr "Pending"

msgid "plugins.generic.peerready.status.reviewing"
msgstr "Reviewing…"

msgid "plugins.generic.peerready.status.complete"
msgstr "Review complete"

msgid "plugins.generic.peerready.status.failed"
msgstr "Review failed"

# ── Settings form ─────────────────────────────────────────────────────────────

msgid "plugins.generic.peerready.settings.apiSection"
msgstr "PeerReady connection settings"

msgid "plugins.generic.peerready.settings.apiSectionDescription"
msgstr "Enter the URL and API key for your PeerReady deployment. These credentials are used to authenticate all server-to-server communication between OJS and PeerReady."

msgid "plugins.generic.peerready.settings.apiUrl"
msgstr "PeerReady URL"

msgid "plugins.generic.peerready.settings.apiUrlDescription"
msgstr "The base URL of your PeerReady deployment. For example: https://peerready.yourinstitution.ac.ug"

msgid "plugins.generic.peerready.settings.apiUrlRequired"
msgstr "A valid PeerReady URL is required."

msgid "plugins.generic.peerready.settings.apiKey"
msgstr "API key"

msgid "plugins.generic.peerready.settings.apiKeyDescription"
msgstr "The PeerReady API key for this journal, created under Settings > API keys in your PeerReady account. Used as a Bearer token in all requests. Keep this confidential."

msgid "plugins.generic.peerready.settings.apiKeyDescriptionV2"
msgstr "Create an API key in your PeerReady account under Settings > API keys. The key needs scopes: review:write, manuscript:write, webhook:manage. It should begin with pr_live_"

msgid "plugins.generic.peerready.settings.apiKeyRequired"
msgstr "An API key is required."

msgid "plugins.generic.peerready.settings.autoMode"
msgstr "Automatically review all new submissions"

msgid "plugins.generic.peerready.settings.autoModeDescription"
msgstr "When enabled, every new manuscript submitted to this journal will be automatically sent to PeerReady for AI review. Disable if you prefer to trigger reviews manually."

msgid "plugins.generic.peerready.settings.testConnection"
msgstr "Test connection"

msgid "plugins.generic.peerready.settings.testTesting"
msgstr "Testing…"

msgid "plugins.generic.peerready.settings.testSuccess"
msgstr "Connected successfully."

msgid "plugins.generic.peerready.settings.testFailed"
msgstr "Connection failed."

msgid "plugins.generic.peerready.settings.testError"
msgstr "Error:"

msgid "plugins.generic.peerready.settings.testMissingFields"
msgstr "Please enter a URL and API key before testing."

# ── Email notification ────────────────────────────────────────────────────────

msgid "emails.PEERREADY_REVIEW_COMPLETE.name"
msgstr "PeerReady review complete"

msgid "emails.PEERREADY_REVIEW_COMPLETE.description"
msgstr "Sent to the assigned editor when PeerReady completes an AI review."

msgid "emails.PEERREADY_REVIEW_COMPLETE.subject"
msgstr "PeerReady review complete: {$title}"

msgid "emails.PEERREADY_REVIEW_COMPLETE.body"
msgstr "Dear {$editorName},

The PeerReady AI review for the following submission has completed.

Title: {$title}
Submission ID: {$submissionId}
Verdict: {$verdict}
Overall Score: {$score}/80

You can view the full review report here:
{$reportUrl}

This is an automated notification from the PeerReady OJS Plugin.

Best regards,
The PeerReady System"
