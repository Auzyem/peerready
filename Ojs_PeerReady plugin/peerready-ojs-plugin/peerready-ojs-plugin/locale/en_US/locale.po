# ── Plugin identity ───────────────────────────────────────────────────────────

msgid "plugins.generic.scholarlens.displayName"
msgstr "ScholarLens AI Manuscript Review"

msgid "plugins.generic.scholarlens.description"
msgstr "Automatically submits manuscripts to ScholarLens for AI-powered peer review scoring, adversarial critique, and journal-fit recommendations. Review reports are attached to the OJS submission workflow."

# ── Sidebar ───────────────────────────────────────────────────────────────────

msgid "plugins.generic.scholarlens.sidebarTitle"
msgstr "ScholarLens AI Review"

msgid "plugins.generic.scholarlens.viewReport"
msgstr "View full report"

msgid "plugins.generic.scholarlens.sessionId"
msgstr "Session"

# ── Status badges ─────────────────────────────────────────────────────────────

msgid "plugins.generic.scholarlens.status.pending"
msgstr "Pending"

msgid "plugins.generic.scholarlens.status.reviewing"
msgstr "Reviewing…"

msgid "plugins.generic.scholarlens.status.complete"
msgstr "Review complete"

msgid "plugins.generic.scholarlens.status.failed"
msgstr "Review failed"

# ── Settings form ─────────────────────────────────────────────────────────────

msgid "plugins.generic.scholarlens.settings.apiSection"
msgstr "ScholarLens connection settings"

msgid "plugins.generic.scholarlens.settings.apiSectionDescription"
msgstr "Enter the URL and API key for your ScholarLens deployment. These credentials are used to authenticate all server-to-server communication between OJS and ScholarLens."

msgid "plugins.generic.scholarlens.settings.apiUrl"
msgstr "ScholarLens URL"

msgid "plugins.generic.scholarlens.settings.apiUrlDescription"
msgstr "The base URL of your ScholarLens deployment. For example: https://scholarlens.yourinstitution.ac.ug"

msgid "plugins.generic.scholarlens.settings.apiUrlRequired"
msgstr "A valid ScholarLens URL is required."

msgid "plugins.generic.scholarlens.settings.apiKey"
msgstr "API key"

msgid "plugins.generic.scholarlens.settings.apiKeyDescription"
msgstr "The ScholarLens API key for this journal, created under Settings > API keys in your ScholarLens account. Used as a Bearer token in all requests. Keep this confidential."

msgid "plugins.generic.scholarlens.settings.apiKeyDescriptionV2"
msgstr "Create an API key in your ScholarLens account under Settings > API keys. The key needs scopes: review:write, manuscript:write, webhook:manage. It should begin with pr_live_"

msgid "plugins.generic.scholarlens.settings.apiKeyRequired"
msgstr "An API key is required."

msgid "plugins.generic.scholarlens.settings.autoMode"
msgstr "Automatically review all new submissions"

msgid "plugins.generic.scholarlens.settings.autoModeDescription"
msgstr "When enabled, every new manuscript submitted to this journal will be automatically sent to ScholarLens for AI review. Disable if you prefer to trigger reviews manually."

msgid "plugins.generic.scholarlens.settings.testConnection"
msgstr "Test connection"

msgid "plugins.generic.scholarlens.settings.testTesting"
msgstr "Testing…"

msgid "plugins.generic.scholarlens.settings.testSuccess"
msgstr "Connected successfully."

msgid "plugins.generic.scholarlens.settings.testFailed"
msgstr "Connection failed."

msgid "plugins.generic.scholarlens.settings.testError"
msgstr "Error:"

msgid "plugins.generic.scholarlens.settings.testMissingFields"
msgstr "Please enter a URL and API key before testing."

# ── Email notification ────────────────────────────────────────────────────────

msgid "emails.PEERREADY_REVIEW_COMPLETE.name"
msgstr "ScholarLens review complete"

msgid "emails.PEERREADY_REVIEW_COMPLETE.description"
msgstr "Sent to the assigned editor when ScholarLens completes an AI review."

msgid "emails.PEERREADY_REVIEW_COMPLETE.subject"
msgstr "ScholarLens review complete: {$title}"

msgid "emails.PEERREADY_REVIEW_COMPLETE.body"
msgstr "Dear {$editorName},

The ScholarLens AI review for the following submission has completed.

Title: {$title}
Submission ID: {$submissionId}
Verdict: {$verdict}
Overall Score: {$score}/80

You can view the full review report here:
{$reportUrl}

This is an automated notification from the ScholarLens OJS Plugin.

Best regards,
The ScholarLens System"
