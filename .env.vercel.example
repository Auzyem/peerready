# ───────────────────────────────────────────────────────────────────────────
# ScholarLens — Vercel environment variables (import template)
#
# HOW TO USE
#   1. Copy this file:           cp .env.vercel.example .env.vercel
#   2. Fill in the real values below (no quotes, no trailing spaces).
#   3. In Vercel: Project → Settings → Environment Variables → "Import .env"
#      and upload/paste .env.vercel. Select the "Production" (and optionally
#      "Preview") environments.
#   4. Redeploy — Vercel only picks up env changes on a new deployment.
#
# SECURITY
#   .env.vercel (the filled-in copy) is gitignored — never commit real secrets.
#   SUPABASE_SERVICE_ROLE_KEY and ANTHROPIC_API_KEY are SERVER-ONLY secrets.
#   They must NOT have a NEXT_PUBLIC_ prefix (that would ship them to browsers).
# ───────────────────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---------------------------------------
# Public project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SECRET. Bypasses RLS. Used only by the detached review
# pipeline (lib/supabase/admin.ts). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (console.anthropic.com → API Keys) ----------------------------
# SECRET. Powers discipline routing, deep review, and adversarial critique.
ANTHROPIC_API_KEY=

# --- App URL (optional) ------------------------------------------------------
# Not currently read by the code, but harmless to set. After your first deploy,
# set this to your production domain, e.g. https://scholarlens.vercel.app
NEXT_PUBLIC_APP_URL=
